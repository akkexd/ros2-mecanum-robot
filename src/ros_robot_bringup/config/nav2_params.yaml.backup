# =============================================================================
# NAV2 PARAMETERS - AGGRESSIVE PARTICLE FILTER + MECANUM OPTIMIZATION
# Designed for: High odometry drift, carpet surface, 30cm+ goals
# Key: Fast AMCL correction + EKF sensor fusion
# =============================================================================

amcl:
  ros__parameters:
    use_sim_time: false
    
    # ============================================
    # MOTION MODEL - CRITICAL FOR MECANUM ON CARPET
    # HIGH VALUES = "Odometry is unreliable, trust laser more"
    # This triggers more aggressive particle spread and resampling
    # ============================================
    alpha1: 0.8      # Rotation error from rotation (high = expect drift)
    alpha2: 0.8      # Rotation error from translation
    alpha3: 0.8      # Translation error from translation
    alpha4: 0.8      # Translation error from rotation
    alpha5: 0.8      # Translation error from strafe (mecanum specific!)
    
    # Frame configuration
    base_frame_id: "base_footprint"
    global_frame_id: "map"
    odom_frame_id: "odom"
    
    # ============================================
    # LASER MODEL - AGGRESSIVE SENSOR UPDATE
    # ============================================
    laser_model_type: "likelihood_field"
    laser_likelihood_max_dist: 2.0
    laser_max_range: 8.0
    laser_min_range: 0.12
    max_beams: 120           # MORE beams = better scan matching
    sigma_hit: 0.15          # Tighter matching
    
    # Beam skip disabled for maximum correction
    do_beamskip: false
    beam_skip_distance: 0.5
    beam_skip_error_threshold: 0.9
    beam_skip_threshold: 0.3
    lambda_short: 0.1
    
    # ============================================
    # PARTICLE FILTER - AGGRESSIVE RESAMPLING
    # More particles + frequent resampling = better convergence
    # ============================================
    max_particles: 8000      # LOTS of particles for coverage
    min_particles: 2000      # Minimum high for stability
    pf_err: 0.01             # Low error threshold = more accurate
    pf_z: 0.99
    resample_interval: 1     # Resample EVERY update (aggressive)
    
    # ============================================
    # RECOVERY - AUTO-FIX WHEN LOST
    # These enable particle spread when localization quality drops
    # ============================================
    recovery_alpha_fast: 0.2    # Fast recovery (higher = more aggressive)
    recovery_alpha_slow: 0.01   # Slow recovery baseline
    
    # ============================================
    # UPDATE FREQUENCY - VERY FREQUENT CORRECTIONS
    # Lower values = AMCL updates more often = faster correction
    # ============================================
    update_min_a: 0.02     # Update every 0.02 rad (~1.1°) rotation
    update_min_d: 0.02     # Update every 2cm movement
    
    # ============================================
    # SENSOR MODEL WEIGHTS - TRUST LASER HEAVILY
    # ============================================
    z_hit: 0.9             # 90% weight on good laser readings
    z_max: 0.02            # 2% weight on max range
    z_rand: 0.05           # 5% random noise
    z_short: 0.03          # 3% short readings
    
    # TF settings
    tf_broadcast: true
    transform_tolerance: 5.0 # Increased from 2.0 to 5.0
    
    set_initial_pose: false      # Let user set initial pose
    initial_pose_x: 0.0
    initial_pose_y: 0.0
    initial_pose_a: 0.0
    # Save pose for recovery
    save_pose_rate: 0.5
    
    # Robot model for mecanum (omnidirectional)
    robot_model_type: "nav2_amcl::OmniMotionModel"
    
    scan_topic: scan

bt_navigator:
  ros__parameters:
    use_sim_time: false
    global_frame: map
    robot_base_frame: base_footprint
    odom_topic: /odom
    bt_loop_duration: 10
    default_server_timeout: 20
    wait_for_service_timeout: 1000
    action_server_result_timeout: 900.0
    navigators: ["navigate_to_pose", "navigate_through_poses"]
    navigate_to_pose:
      plugin: "nav2_bt_navigator::NavigateToPoseNavigator"
    navigate_through_poses:
      plugin: "nav2_bt_navigator::NavigateThroughPosesNavigator"

controller_server:
  ros__parameters:
    use_sim_time: false
    
    # Controller at 10Hz - stable for Pi5
    controller_frequency: 10.0
    
    min_x_velocity_threshold: 0.001
    min_y_velocity_threshold: 0.001
    min_theta_velocity_threshold: 0.001
    failure_tolerance: 0.5
    
    progress_checker_plugins: ["progress_checker"]
    goal_checker_plugins: ["general_goal_checker"]
    controller_plugins: ["FollowPath"]
    
    # ============================================
    # PROGRESS CHECKER - Lenient for slow careful movement
    # ============================================
    progress_checker:
      plugin: "nav2_controller::SimpleProgressChecker"
      required_movement_radius: 0.08    # Need 8cm progress
      movement_time_allowance: 30.0     # 30 seconds allowed
    
    # ============================================
    # GOAL CHECKER
    # ============================================
    general_goal_checker:
      stateful: True
      plugin: "nav2_controller::SimpleGoalChecker"
      xy_goal_tolerance: 0.08          # 8cm position tolerance
      yaw_goal_tolerance: 0.15         # ~8.5° orientation tolerance
    
    # ============================================
    # DWB LOCAL PLANNER - SLOW SAFE MECANUM MOTION
    # ============================================
    FollowPath:
      plugin: "dwb_core::DWBLocalPlanner"
      debug_trajectory_details: False
      
      # ------------------------------------------
      # VELOCITY LIMITS - SLOW FOR AMCL TO TRACK
      # ------------------------------------------
      min_vel_x: -0.06         # Slow reverse
      min_vel_y: -0.06         # Slow strafe
      max_vel_x: 0.10          # 10 cm/s forward MAX
      max_vel_y: 0.06          # 6 cm/s strafe MAX
      max_vel_theta: 0.4       # ~23°/s rotation MAX
      
      min_speed_xy: 0.0
      max_speed_xy: 0.10
      min_speed_theta: 0.0
      
      # ------------------------------------------
      # ACCELERATION - VERY GENTLE
      # ------------------------------------------
      acc_lim_x: 0.2           # Gentle acceleration
      acc_lim_y: 0.2
      acc_lim_theta: 0.3
      decel_lim_x: -0.2
      decel_lim_y: -0.2
      decel_lim_theta: -0.3
      
      # ------------------------------------------
      # TRAJECTORY SAMPLING
      # ------------------------------------------
      vx_samples: 15
      vy_samples: 5
      vtheta_samples: 20
      sim_time: 3.0            # Look ahead 3 seconds
      linear_granularity: 0.05
      angular_granularity: 0.025
      
      # ------------------------------------------
      # TOLERANCES
      # ------------------------------------------
      transform_tolerance: 1.0
      xy_goal_tolerance: 0.08
      trans_stopped_velocity: 0.08
      short_circuit_trajectory_evaluation: True
      stateful: True
      
      # ------------------------------------------
      # CRITICS - BALANCED FOR SMOOTH MOTION
      # ------------------------------------------
      critics: ["RotateToGoal", "Oscillation", "BaseObstacle", "GoalAlign", "PathAlign", "PathDist", "GoalDist"]
      
      BaseObstacle.scale: 0.02
      PathAlign.scale: 32.0
      PathAlign.forward_point_distance: 0.1
      PathDist.scale: 32.0
      GoalAlign.scale: 24.0
      GoalAlign.forward_point_distance: 0.1
      GoalDist.scale: 24.0
      RotateToGoal.scale: 32.0
      RotateToGoal.slowing_factor: 5.0
      RotateToGoal.lookahead_time: -1.0
      Oscillation.scale: 1.0

# ============================================
# LOCAL COSTMAP - PREVENT STACKING
# ============================================
local_costmap:
  local_costmap:
    ros__parameters:
      update_frequency: 5.0
      publish_frequency: 2.0
      global_frame: odom
      robot_base_frame: base_footprint
      use_sim_time: false
      
      rolling_window: true
      width: 3
      height: 3
      resolution: 0.05
      robot_radius: 0.18
      
      # High transform tolerance
      transform_tolerance: 1.0
      
      # ============================================
      # PLUGINS - OBSTACLE CLEARING ENABLED
      # ============================================
      plugins: ["obstacle_layer", "inflation_layer"]
      
      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan
        combination_method: 1        # Overwrite (prevents stacking)
        
        scan:
          topic: /scan
          data_type: "LaserScan"
          marking: True
          clearing: True             # CLEAR old obstacles
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 2.5
          obstacle_min_range: 0.0
          raytrace_max_range: 3.5    # Clear beyond obstacle range
          raytrace_min_range: 0.0
          inf_is_valid: False
          
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 2.5
        inflation_radius: 0.35
        
      always_send_full_costmap: True

# ============================================
# GLOBAL COSTMAP - PREVENT STACKING
# ============================================
global_costmap:
  global_costmap:
    ros__parameters:
      update_frequency: 1.0
      publish_frequency: 1.0
      global_frame: map
      robot_base_frame: base_footprint
      use_sim_time: false
      
      robot_radius: 0.18
      resolution: 0.05
      track_unknown_space: true
      
      transform_tolerance: 1.0
      
      plugins: ["static_layer", "obstacle_layer", "inflation_layer"]
      
      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: True
        enabled: True
        
      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan
        combination_method: 1        # Overwrite (prevents stacking)
        
        scan:
          topic: /scan
          data_type: "LaserScan"
          marking: True
          clearing: True             # CLEAR old obstacles
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 2.5
          obstacle_min_range: 0.0
          raytrace_max_range: 3.5
          raytrace_min_range: 0.0
          inf_is_valid: False
          
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 2.5
        inflation_radius: 0.35
        
      always_send_full_costmap: True

map_server:
  ros__parameters:
    use_sim_time: false
    yaml_filename: ""

planner_server:
  ros__parameters:
    expected_planner_frequency: 5.0
    use_sim_time: false
    planner_plugins: ["GridBased"]
    
    GridBased:
      plugin: "nav2_navfn_planner::NavfnPlanner"
      tolerance: 0.5
      use_astar: false
      allow_unknown: true

behavior_server:
  ros__parameters:
    costmap_topic: local_costmap/costmap_raw
    footprint_topic: local_costmap/published_footprint
    cycle_frequency: 10.0
    behavior_plugins: ["spin", "backup", "drive_on_heading", "wait"]
    
    spin:
      plugin: "nav2_behaviors::Spin"
    backup:
      plugin: "nav2_behaviors::BackUp"
    drive_on_heading:
      plugin: "nav2_behaviors::DriveOnHeading"
    wait:
      plugin: "nav2_behaviors::Wait"
      
    global_frame: odom
    robot_base_frame: base_footprint
    transform_tolerance: 1.0
    use_sim_time: false
    simulate_ahead_time: 2.0
    
    # Slow recovery movements
    max_rotational_vel: 0.25
    min_rotational_vel: 0.08
    rotational_acc_lim: 0.3
