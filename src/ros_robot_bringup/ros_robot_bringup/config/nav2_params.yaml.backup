# =============================================================================
# MERGED NAV2 PARAMETERS
# = Old aggressive AMCL (compensates for sparse encoder data)
# + New optimizations (A*, 20Hz controller, faster costmaps)
# + RealSense depth camera obstacle avoidance (depth_scan)
# =============================================================================
amcl:
  ros__parameters:
    use_sim_time: false
    
    # ============================================
    # MOTION MODEL - AGGRESSIVE (from old config)
    # HIGH VALUES because encoder data is sparse/drops to zero
    # This tells AMCL: "don't trust odometry, trust laser more"
    # ============================================
    alpha1: 0.8      # Rotation error from rotation
    alpha2: 0.8      # Rotation error from translation
    alpha3: 0.8      # Translation error from translation
    alpha4: 0.8      # Translation error from rotation
    alpha5: 0.8      # Translation error from strafe (mecanum)
    
    # Frame configuration
    base_frame_id: "base_footprint"
    global_frame_id: "map"
    odom_frame_id: "odom"
    
    # ============================================
    # LASER MODEL - AGGRESSIVE SCAN MATCHING (from old)
    # ============================================
    laser_model_type: "likelihood_field"
    laser_likelihood_max_dist: 2.0
    laser_max_range: 8.0
    laser_min_range: 0.12
    max_beams: 120
    sigma_hit: 0.15
    
    do_beamskip: false
    beam_skip_distance: 0.5
    beam_skip_error_threshold: 0.9
    beam_skip_threshold: 0.3
    lambda_short: 0.1
    
    # ============================================
    # PARTICLE FILTER - AGGRESSIVE (from old)
    # ============================================
    max_particles: 5000
    min_particles: 1000
    pf_err: 0.01
    pf_z: 0.99
    resample_interval: 1
    
    recovery_alpha_fast: 0.2
    recovery_alpha_slow: 0.01
    
    # ============================================
    # UPDATE FREQUENCY - VERY FREQUENT (from old)
    # ============================================
    update_min_a: 0.02
    update_min_d: 0.02
    
    z_hit: 0.9
    z_max: 0.02
    z_rand: 0.05
    z_short: 0.03
    
    tf_broadcast: true
    transform_tolerance: 1.0
    save_pose_rate: 0.5
    
    set_initial_pose: true
    initial_pose_x: 0.0
    initial_pose_y: -0.31
    initial_pose_a: 0.0
    
    robot_model_type: "nav2_amcl::OmniMotionModel"
    
    scan_topic: scan

# ============================================
# BT NAVIGATOR
# ============================================
bt_navigator:
  ros__parameters:
    use_sim_time: false
    global_frame: map
    robot_base_frame: base_footprint
    odom_topic: /odom
    bt_loop_duration: 10
    default_server_timeout: 30  #was 20
    wait_for_service_timeout: 1000
    action_server_result_timeout: 900.0
    navigators: ["navigate_to_pose", "navigate_through_poses"]
    navigate_to_pose:
      plugin: "nav2_bt_navigator::NavigateToPoseNavigator"
    navigate_through_poses:
      plugin: "nav2_bt_navigator::NavigateThroughPosesNavigator"
    error_code_names:
      - compute_path_error_code
      - follow_path_error_code

# ============================================
# CONTROLLER SERVER
# ============================================
controller_server:
  ros__parameters:
    use_sim_time: false
    
    controller_frequency: 10.0
    
    min_x_velocity_threshold: 0.01
    min_y_velocity_threshold: 0.01
    min_theta_velocity_threshold: 0.001
    failure_tolerance: 0.5
    
    progress_checker_plugins: ["progress_checker"]
    goal_checker_plugins: ["general_goal_checker"]
    controller_plugins: ["FollowPath"]
    
    progress_checker:
      plugin: "nav2_controller::SimpleProgressChecker"
      required_movement_radius: 0.08
      movement_time_allowance: 60.0
    
    general_goal_checker:
      stateful: True
      plugin: "nav2_controller::SimpleGoalChecker"
      xy_goal_tolerance: 0.25
      yaw_goal_tolerance: 3.14
    
    # ============================================
    # DWB LOCAL PLANNER
    # ============================================
    FollowPath:
      plugin: "dwb_core::DWBLocalPlanner"
      debug_trajectory_details: False
      
      min_vel_x: -0.04
      min_vel_y: -0.04
      max_vel_x: 0.04
      max_vel_y: 0.04
      max_vel_theta: 0.0
      
      min_speed_xy: 0.0
      max_speed_xy: 0.045
      min_speed_theta: 0.0
      
      acc_lim_x: 0.15
      acc_lim_y: 0.15
      acc_lim_theta: 0.0
      decel_lim_x: -0.15
      decel_lim_y: -0.15
      decel_lim_theta: 0.0
      
      vx_samples: 20
      vy_samples: 10
      vtheta_samples: 1
      sim_time: 2.0
      linear_granularity: 0.05
      angular_granularity: 0.025
      
      transform_tolerance: 1.0
      xy_goal_tolerance: 0.25
      trans_stopped_velocity: 0.01
      short_circuit_trajectory_evaluation: True
      stateful: False
      
      critics: ["Oscillation", "BaseObstacle", "PathDist", "GoalDist"]
      BaseObstacle.scale: 0.02
      PathDist.scale: 16.0
      GoalDist.scale: 24.0
      Oscillation.scale: 10.0

# ============================================
# LOCAL COSTMAP — DUAL SENSOR (RPLIDAR + RealSense)
# ============================================
local_costmap:
  local_costmap:
    ros__parameters:
      update_frequency: 10.0
      publish_frequency: 5.0
      global_frame: odom
      robot_base_frame: base_footprint
      use_sim_time: false
      
      rolling_window: true
      width: 3
      height: 3
      resolution: 0.05
      robot_radius: 0.18
      
      transform_tolerance: 1.0
      
      plugins: ["obstacle_layer", "inflation_layer"]
      
      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan depth_scan
        combination_method: 1
        
        # Source 1: RPLIDAR — 360° coverage, marks + clears
        scan:
          topic: /scan
          data_type: "LaserScan"
          marking: True
          clearing: True
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 3.0
          obstacle_min_range: 0.0
          raytrace_max_range: 4.0
          raytrace_min_range: 0.0
          inf_is_valid: False
        
        # Source 2: RealSense depth camera — forward-facing, marks only
        # Catches obstacles above/below RPLIDAR plane (table edges, etc.)
        # observation_persistence=3.0: dynamic objects fade after 3 seconds
        depth_scan:
          topic: /camera_scan
          data_type: "LaserScan"
          marking: True
          clearing: False
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 2.5
          obstacle_min_range: 0.20
          raytrace_max_range: 3.0
          raytrace_min_range: 0.20
          inf_is_valid: False
          observation_persistence: 3.0
          
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 2.5
        inflation_radius: 0.25 #was 0.35 - too wide for doorways
        
      always_send_full_costmap: True

# ============================================
# GLOBAL COSTMAP — DUAL SENSOR (RPLIDAR + RealSense)
# ============================================
global_costmap:
  global_costmap:
    ros__parameters:
      update_frequency: 2.0
      publish_frequency: 1.0
      global_frame: map
      robot_base_frame: base_footprint
      use_sim_time: false
      
      robot_radius: 0.18
      resolution: 0.05
      track_unknown_space: true
      
      transform_tolerance: 1.0
      
      plugins: ["static_layer", "obstacle_layer", "inflation_layer"]
      
      static_layer:
        plugin: "nav2_costmap_2d::StaticLayer"
        map_subscribe_transient_local: True
        enabled: True
        
      obstacle_layer:
        plugin: "nav2_costmap_2d::ObstacleLayer"
        enabled: True
        observation_sources: scan depth_scan
        combination_method: 1
        
        # Source 1: RPLIDAR — 360° coverage, marks + clears
        scan:
          topic: /scan
          data_type: "LaserScan"
          marking: True
          clearing: True
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 3.0
          obstacle_min_range: 0.0
          raytrace_max_range: 4.0
          raytrace_min_range: 0.0
          inf_is_valid: False
        
        # Source 2: RealSense depth camera — forward-facing, marks only
        depth_scan:
          topic: /camera_scan
          data_type: "LaserScan"
          marking: True
          clearing: False
          max_obstacle_height: 2.0
          min_obstacle_height: 0.0
          obstacle_max_range: 2.5
          obstacle_min_range: 0.20
          raytrace_max_range: 3.0
          raytrace_min_range: 0.20
          inf_is_valid: False
          observation_persistence: 3.0
          
      inflation_layer:
        plugin: "nav2_costmap_2d::InflationLayer"
        cost_scaling_factor: 2.5
        inflation_radius: 0.20 #was0.25 #was 0.35 - too wide for doorways
        
      always_send_full_costmap: True

# ============================================
# MAP SERVER
# ============================================
map_server:
  ros__parameters:
    use_sim_time: false
    yaml_filename: ""

# ============================================
# PLANNER SERVER — A* ENABLED
# ============================================
planner_server:
  ros__parameters:
    expected_planner_frequency: 20.0
    use_sim_time: false
    planner_plugins: ["GridBased"]
    
    GridBased:
      plugin: "nav2_navfn_planner::NavfnPlanner"
      tolerance: 0.50 #was 0.25
      use_astar: true
      allow_unknown: true

# ============================================
# BEHAVIOR SERVER
# ============================================
behavior_server:
  ros__parameters:
    costmap_topic: local_costmap/costmap_raw
    footprint_topic: local_costmap/published_footprint
    cycle_frequency: 10.0
    behavior_plugins: ["spin", "backup", "drive_on_heading", "wait"]
    spin:
      plugin: "nav2_behaviors::Spin"
    backup:
      plugin: "nav2_behaviors::BackUp"
    drive_on_heading:
      plugin: "nav2_behaviors::DriveOnHeading"
    wait:
      plugin: "nav2_behaviors::Wait"
      
    global_frame: odom
    robot_base_frame: base_footprint
    transform_tolerance: 1.0
    use_sim_time: false
    simulate_ahead_time: 2.0
    
    max_rotational_vel: 0.15
    min_rotational_vel: 0.08
    rotational_acc_lim: 0.5